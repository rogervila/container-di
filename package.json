{
    "name": "container-di",
    "version": "3.0.0",
    "description": "A lightweight PSR-11-style dependency injection container for TypeScript",
    "author": "Roger Vilà",
    "license": "MIT",
    "type": "module",
    "main": "dist/container-di.umd.cjs",
    "module": "dist/container-di.js",
    "types": "dist/container-di.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/container-di.d.ts",
            "import": "./dist/container-di.js",
            "require": "./dist/container-di.umd.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "start": "vite",
        "build": "tsc && vite build",
        "check:workers": "pnpm build && node scripts/check-workers-compatibility.mjs",
        "test": "vitest run --dom",
        "format": "npx @biomejs/biome check --write",
        "lint": "tsc && npx @biomejs/biome ci ."
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.0",
        "happy-dom": "^20.10.5",
        "typescript": "~6.0.3",
        "vite": "^7.3.5",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.9"
    }
}
